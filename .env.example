# ==============================================================================
# MING Stack Environment Configuration
# ==============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# IMPORTANT: Change all default passwords and tokens before production use!
# ==============================================================================

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
TZ=UTC

# ------------------------------------------------------------------------------
# InfluxDB
# ------------------------------------------------------------------------------
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpassword
INFLUXDB_ORG=ming
INFLUXDB_TOKEN=p4n4-stack-token

# Primary bucket (created automatically by InfluxDB init, 30d retention)
INFLUXDB_BUCKET=raw_telemetry

# Additional buckets (created by init-buckets.sh)
INFLUXDB_BUCKET_PROCESSED=processed_metrics   # downsampled data, 365d
INFLUXDB_BUCKET_AI_EVENTS=ai_events           # AI annotations & anomaly flags, infinite
INFLUXDB_BUCKET_HEALTH=system_health          # stack component metrics, 7d

# Sandbox bucket for development/testing
INFLUXDB_SANDBOX_BUCKET=sandbox
INFLUXDB_SANDBOX_RETENTION=30d

# ------------------------------------------------------------------------------
# Grafana
# ------------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=adminpassword
