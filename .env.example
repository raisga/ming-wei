# ==============================================================================
# MING Stack Environment Configuration
# ==============================================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# General
# ------------------------------------------------------------------------------
TZ=UTC

# ------------------------------------------------------------------------------
# InfluxDB
# ------------------------------------------------------------------------------
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpassword
INFLUXDB_ORG=ming
INFLUXDB_BUCKET=iot
INFLUXDB_SANDBOX_BUCKET=sandbox
INFLUXDB_SANDBOX_RETENTION=30d
INFLUXDB_TOKEN=p4n4-stack-token

# ------------------------------------------------------------------------------
# Grafana
# ------------------------------------------------------------------------------
GRAFANA_USER=admin
GRAFANA_PASSWORD=adminpassword
